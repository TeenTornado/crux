# ── Evidence-to-Experiment Assistant · environment ─────────────────────────
# Copy this file to .env.local and fill in your key.
#   cp .env.example .env.local

# Google AI Studio key (https://aistudio.google.com/apikey).
# Without a key, the app still runs fully in DEMO MODE (pre-baked papers,
# reconciliation, and experiment plans). With a key, uploads and the "Re-run
# live" controls call real Gemma 4 + Gemini.
GEMINI_API_KEY=

# ── Model routing ──────────────────────────────────────────────────────────
# Extraction runs on Gemma 4 (the on-device / privacy tier).
GEMMA_MODEL=gemma-4-31b-it
# Reconciliation + experiment generation run on a Gemini "thinking" model.
GEMINI_RECONCILE_MODEL=gemini-3-flash-preview
GEMINI_EXPERIMENT_MODEL=gemini-3-flash-preview
# The low-latency chat layer.
GEMINI_CHAT_MODEL=gemini-flash-latest

# ── Optional: real on-device Gemma via Ollama ──────────────────────────────
# In production the extraction tier is meant to run locally for privacy.
# Install Ollama, `ollama pull gemma3`, then set these and /extract will use it.
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_GEMMA_MODEL=gemma4:e4b
# Keep the model resident between chunks/uploads so no chunk pays the cold-load
# cost ("-1" = forever; a duration like "10m" also works). Phase 5.1.
# OLLAMA_KEEP_ALIVE=-1
# Per-chunk timeout before the chunk degrades to the hosted tier. Phase 5.3.
# OLLAMA_CHUNK_TIMEOUT_MS=120000
# Chunks per paper (sequential, ~40-90s each on local e4b) — total extract time
# ≈ papers × chunks × chunk-time. Set 3 for live demos to roughly halve it;
# headline-number recall is protected by results-first ordering + the miner.
# EXTRACT_MAX_CHUNKS=6
# Local Mode: adjudication + experiment generation go straight to on-device
# Gemma (skip the cloud attempt entirely) — the WiFi-off demo path.
# RECONCILE_BACKEND=local
