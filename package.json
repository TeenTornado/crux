{
  "name": "crux",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Crux — extracts structured claims, diagnoses why papers disagree, and generates the experiment that settles it.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "eval": "tsx eval/run.ts",
    "eval:fixtures": "tsx eval/fixtures.ts",
    "eval:contra": "tsx eval/contra.ts",
    "electron:dev": "ELECTRON_DEV=1 electron .",
    "electron:prepare": "next build && rm -rf desktop-server && cp -R .next/standalone desktop-server && rm -rf desktop-server/.next/static && cp -R .next/static desktop-server/.next/static && ([ -d public ] && cp -R public desktop-server/public || true)",
    "electron:build": "npm run electron:prepare && electron-builder --mac dmg zip"
  },
  "dependencies": {
    "@google/genai": "^0.3.1",
    "@xyflow/react": "^12.3.6",
    "framer-motion": "^11.15.0",
    "idb": "^8.0.3",
    "lucide-react": "^0.469.0",
    "next": "^15.5.20",
    "node-html-parser": "^9.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "unpdf": "^0.12.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.49",
    "puppeteer-core": "^25.3.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.0",
    "typescript": "^5.7.2"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "dev.crux.app",
    "productName": "Crux",
    "asar": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "desktop-server/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "public/Crux_Logo.png"
    },
    "npmRebuild": false,
    "extraMetadata": {
      "main": "electron/main.js",
      "dependencies": {}
    }
  }
}
